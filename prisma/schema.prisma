generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum NotificationIntervalType {
  DAY_180
  DAY_90
  DAY_60
  DAY_42
  DAY_30
  DAY_14
  DAY_12
  DAY_10
  DAY_8
  DAY_2
}

enum NotificationActionType {
  DELIVERY_REMINDER
  DELIVERY_CONFIRMATION_REQUEST
  PAYMENT_REQUEST
  PAYMENT_ENFORCEMENT
  BACKORDER_REPORT
  INTERNAL_EMAIL
  MANUAL_REVIEW
}

enum NotificationChannel {
  SMS   @map("sms")
  EMAIL @map("email")
}

enum NotificationEventStatus {
  PENDING      @map("pending")
  SCHEDULED    @map("scheduled")
  SKIPPED      @map("skipped")
  SENT         @map("sent")
  FAILED       @map("failed")
  CANCELLED    @map("cancelled")
  DEDUPED      @map("deduped")
  ALREADY_SENT @map("already_sent")
}

enum InternalOrderLifecycleStatus {
  ACTIVE                 @map("active")
  PAYMENT_PENDING        @map("payment_pending")
  DELIVERY_BUMPED_UNPAID @map("delivery_bumped_unpaid")
  BLOCKED                @map("blocked")
  MANUAL_REVIEW          @map("manual_review")
  COMPLETED              @map("completed")
  CANCELLED              @map("cancelled")
}

enum DeliveryConfirmationStatus {
  PENDING            @map("pending")
  CONFIRMED          @map("confirmed")
  CHANGE_REQUESTED   @map("change_requested")
  AWAITING_NEW_DATE  @map("awaiting_new_date")
  NEW_DATE_REQUESTED @map("new_date_requested")
  INCOMPLETE         @map("incomplete")
  UNRECOGNIZED       @map("unrecognized")
  EXPIRED            @map("expired")
}

model Contact {
  id             String    @id @default(cuid())
  contactId      String    @unique @db.VarChar(64)
  status         String?   @db.VarChar(64)
  companyName    String?   @db.VarChar(256)
  displayName    String?   @db.VarChar(256)
  firstName      String?   @db.VarChar(128)
  lastName       String?   @db.VarChar(128)
  email          String?   @db.VarChar(256)
  phone1         String?   @db.VarChar(32)
  phone2         String?   @db.VarChar(32)
  smsOptIn       Boolean   @default(false)
  emailOptIn     Boolean   @default(true)
  phoneCallOptIn Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastSyncedAt   DateTime?

  orders                Order[]
  notificationEvents    NotificationEvent[]
  smsOptOuts            SmsOptOut[]
  emailOptOuts          EmailOptOut[]
  deliveryConfirmations DeliveryConfirmation[]

  @@index([contactId])
  @@index([email])
  @@index([status])
  @@map("contacts")
}

model Order {
  id                      String                       @id @default(cuid())
  orderType               String                       @db.VarChar(16)
  orderNumber             String                       @db.VarChar(64)
  shipVia                 String?                      @db.VarChar(64)
  status                  String?                      @db.VarChar(64)
  headerRequestedOn       DateTime?                    @db.Date
  customerId              String?                      @db.VarChar(64)
  customerDescription     String?                      @db.VarChar(256)
  contactId               String                       @db.VarChar(64)
  locationId              String?                      @db.VarChar(64)
  locationDescription     String?                      @db.VarChar(256)
  turnInDate              DateTime?                    @db.Date
  noteId                  String?                      @db.VarChar(64)
  internalLifecycleStatus InternalOrderLifecycleStatus @default(ACTIVE)
  lifecycleReason         String?                      @db.VarChar(1024)
  lifecycleUpdatedAt      DateTime?
  buyerGroup              String?                      @db.VarChar(64)
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  lastSyncedAt            DateTime?

  contact               Contact                @relation(fields: [contactId], references: [contactId], onDelete: Restrict)
  total                 OrderTotal?
  lines                 OrderLine[]
  address               OrderAddress?
  taxDetails            OrderTaxDetail[]
  deliveryGroups        OrderDeliveryGroup[]
  notificationEvents    NotificationEvent[]
  deliveryConfirmations DeliveryConfirmation[]

  @@unique([orderType, orderNumber])
  @@index([orderNumber])
  @@index([contactId])
  @@index([customerId])
  @@index([headerRequestedOn])
  @@index([status])
  @@index([internalLifecycleStatus])
  @@index([buyerGroup])
  @@map("orders")
}

model OrderTotal {
  id              String    @id @default(cuid())
  orderId         String    @unique
  orderNumber     String    @db.VarChar(64)
  unpaidBalance   Decimal?  @db.Decimal(18, 2)
  orderTotal      Decimal?  @db.Decimal(18, 2)
  taxTotal        Decimal?  @db.Decimal(18, 2)
  lineTotalAmount Decimal?  @db.Decimal(18, 2)
  unbilledAmount  Decimal?  @db.Decimal(18, 2)
  unbilledQty     Decimal?  @db.Decimal(18, 4)
  paymentTerms    String?   @map("payment_terms") @db.VarChar(64)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastSyncedAt    DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderNumber])
  @@map("order_totals")
}

model OrderLine {
  id                    String    @id @default(cuid())
  orderId               String
  orderType             String    @db.VarChar(16)
  orderNumber           String    @db.VarChar(64)
  requestedOn           DateTime? @db.Date
  lineNbr               Int
  inventoryId           String?   @db.VarChar(128)
  lineDescription       String?   @db.VarChar(512)
  itemType              String?   @db.VarChar(64)
  itemClass             String?   @db.VarChar(64)
  taxCategory           String?   @db.VarChar(64)
  eta                   DateTime? @db.Date
  orderQty              Decimal?  @db.Decimal(18, 4)
  openQty               Decimal?  @db.Decimal(18, 4)
  activeAllocatedQty    Decimal?  @db.Decimal(18, 4)
  allocationStatus      String?   @db.VarChar(64)
  etaStatus             String?   @db.VarChar(64)
  readinessStatus       String?   @db.VarChar(64)
  displayStatus         String?   @db.VarChar(128)
  readinessCalculatedAt DateTime?
  discountedUnitPrice   Decimal?  @db.Decimal(18, 2)
  warehouseId           String?   @db.VarChar(64)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  lastSyncedAt          DateTime?

  order       Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  allocations OrderLineAllocation[]

  @@unique([orderId, lineNbr])
  @@index([orderNumber])
  @@index([orderType, orderNumber])
  @@index([inventoryId])
  @@index([taxCategory])
  @@index([requestedOn])
  @@index([orderId, requestedOn])
  @@map("order_lines")
}

model OrderTaxDetail {
  id              String    @id @default(cuid())
  orderId         String
  orderType       String    @db.VarChar(16)
  orderNumber     String    @db.VarChar(64)
  rowNumber       Int?
  lineNbr         Int?
  recordId        String?   @db.VarChar(64)
  taxId           String?   @db.VarChar(128)
  taxCategory     String?   @db.VarChar(64)
  taxType         String?   @db.VarChar(64)
  customerTaxZone String?   @db.VarChar(128)
  taxRate         Decimal?  @db.Decimal(18, 6)
  taxableAmount   Decimal?  @db.Decimal(18, 2)
  taxAmount       Decimal?  @db.Decimal(18, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastSyncedAt    DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderNumber])
  @@index([orderType, orderNumber])
  @@index([taxId])
  @@index([taxCategory])
  @@index([taxType])
  @@index([customerTaxZone])
  @@map("order_tax_details")
}

model OrderLineAllocation {
  id           String    @id @default(cuid())
  orderLineId  String
  orderType    String    @db.VarChar(16)
  orderNumber  String    @db.VarChar(64)
  lineNbr      Int
  splitLineNbr Int
  inventoryId  String?   @db.VarChar(128)
  allocated    Boolean   @default(false)
  completed    Boolean   @default(false)
  qty          Decimal?  @db.Decimal(18, 4)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSyncedAt DateTime?

  orderLine OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)

  @@unique([orderLineId, splitLineNbr])
  @@index([orderNumber])
  @@index([orderType, orderNumber])
  @@index([inventoryId])
  @@map("order_line_allocations")
}

model OrderAddress {
  id           String    @id @default(cuid())
  orderId      String    @unique
  addressLine1 String?   @db.VarChar(256)
  addressLine2 String?   @db.VarChar(256)
  city         String?   @db.VarChar(128)
  country      String?   @db.VarChar(64)
  postalCode   String?   @db.VarChar(32)
  state        String?   @db.VarChar(64)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSyncedAt DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_addresses")
}

model OrderDeliveryGroup {
  id               String    @id @default(cuid())
  orderId          String
  orderNumber      String    @db.VarChar(64)
  orderType        String    @db.VarChar(16)
  deliveryDate     DateTime  @db.Date
  status           String?   @db.VarChar(64)
  isActive         Boolean   @default(true)
  supersededAt     DateTime?
  supersededReason String?   @db.VarChar(256)
  lineCount        Int?
  lastSeenAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastSyncedAt     DateTime?

  order                 Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  notificationEvents    NotificationEvent[]
  deliveryConfirmations DeliveryConfirmation[]

  @@unique([orderId, deliveryDate])
  @@index([orderNumber])
  @@index([orderType, orderNumber])
  @@index([deliveryDate])
  @@index([isActive, deliveryDate])
  @@index([status])
  @@map("order_delivery_groups")
}

model ErpChangeEvent {
  id String @id @default(cuid())

  changeType String  @db.VarChar(64)
  entityType String  @db.VarChar(64)
  entityId   String? @db.VarChar(128)
  entityKey  String  @db.VarChar(256)
  fieldName  String? @db.VarChar(128)

  orderId     String? @db.VarChar(128)
  orderType   String? @db.VarChar(16)
  orderNumber String? @db.VarChar(64)

  orderLineId           String? @db.VarChar(128)
  orderDeliveryGroupId  String? @db.VarChar(128)
  orderLineAllocationId String? @db.VarChar(128)

  lineNbr      Int?
  splitLineNbr Int?
  deliveryDate DateTime? @db.Date

  oldValue Json?
  newValue Json?

  summary  String? @db.VarChar(1024)
  severity String? @db.VarChar(32)

  changeKey String @unique @db.VarChar(512)

  status String @default("detected") @db.VarChar(32)

  detectedAt  DateTime  @default(now())
  processedAt DateTime?
  ignoredAt   DateTime?

  source      String? @default("acumatica") @db.VarChar(64)
  importRunId String? @db.VarChar(128)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([changeType])
  @@index([entityType])
  @@index([entityKey])
  @@index([orderId])
  @@index([orderNumber])
  @@index([orderType, orderNumber])
  @@index([orderLineId])
  @@index([orderDeliveryGroupId])
  @@index([orderLineAllocationId])
  @@index([status])
  @@index([detectedAt])
  @@index([importRunId])
  @@map("erp_change_events")
}

model NotificationEvent {
  id                String                   @id @default(cuid())
  orderId           String
  deliveryGroupId   String                   @map("orderDeliveryGroupId")
  contactId         String                   @db.VarChar(64)
  orderType         String                   @db.VarChar(16)
  orderNumber       String                   @db.VarChar(64)
  deliveryDate      DateTime                 @db.Date
  intervalType      NotificationIntervalType
  actionType        NotificationActionType
  dedupeKey         String                   @unique @db.VarChar(512)
  selectedChannel   NotificationChannel?
  channelReason     String?                  @db.VarChar(256)
  recipientEmail    String?                  @db.VarChar(256)
  recipientPhone    String?                  @db.VarChar(32)
  status            NotificationEventStatus  @default(PENDING)
  reasonSkipped     String?                  @db.VarChar(1024)
  reasonFailed      String?                  @db.VarChar(1024)
  provider          String?                  @db.VarChar(64)
  externalMessageId String?                  @db.VarChar(256)
  scheduledAt       DateTime?
  triggeredAt       DateTime?
  sentAt            DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  orderDeliveryGroup    OrderDeliveryGroup     @relation(fields: [deliveryGroupId], references: [id], onDelete: Cascade)
  order                 Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  contact               Contact                @relation(fields: [contactId], references: [contactId], onDelete: Restrict)
  attempts              NotificationAttempt[]
  deliveryConfirmations DeliveryConfirmation[]

  @@index([deliveryGroupId])
  @@index([orderId])
  @@index([contactId])
  @@index([orderType, orderNumber])
  @@index([deliveryDate])
  @@index([intervalType])
  @@index([actionType])
  @@index([selectedChannel])
  @@index([status])
  @@index([scheduledAt])
  @@index([triggeredAt])
  @@index([sentAt])
  @@map("notification_events")
}

model NotificationAttempt {
  id                  String              @id @default(cuid())
  notificationEventId String
  attemptNumber       Int
  channel             NotificationChannel
  provider            String?             @db.VarChar(64)
  success             Boolean             @default(false)
  errorMessage        String?             @db.VarChar(1024)
  providerCode        String?             @db.VarChar(128)
  httpStatus          Int?
  externalMessageId   String?             @db.VarChar(256)
  sentAt              DateTime?
  createdAt           DateTime            @default(now())

  notificationEvent NotificationEvent @relation(fields: [notificationEventId], references: [id], onDelete: Cascade)

  @@unique([notificationEventId, attemptNumber])
  @@index([notificationEventId])
  @@index([channel])
  @@index([provider])
  @@index([success])
  @@index([externalMessageId])
  @@map("notification_attempts")
}

model DeliveryConfirmation {
  id                  String                     @id @default(cuid())
  orderId             String
  deliveryGroupId     String                     @map("orderDeliveryGroupId")
  notificationEventId String?
  orderType           String                     @db.VarChar(16)
  orderNumber         String                     @db.VarChar(64)
  deliveryDate        DateTime                   @db.Date
  contactId           String                     @db.VarChar(64)
  status              DeliveryConfirmationStatus @default(PENDING)
  responseChannel     NotificationChannel?
  rawResponse         String?                    @db.VarChar(1024)
  normalizedResponse  String?                    @db.VarChar(128)
  confirmedAt         DateTime?
  changeRequestedAt   DateTime?
  requestedNewDate    DateTime?                  @db.Date
  requestedNewDateRaw String?                    @db.VarChar(64)
  requestedNewDateAt  DateTime?
  reminderSentAt      DateTime?
  noResponseAt        DateTime?
  linkToken           String?                    @unique @db.VarChar(128)
  linkCreatedAt       DateTime?
  linkExpiresAt       DateTime?
  linkExpiredAt       DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  order              Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderDeliveryGroup OrderDeliveryGroup @relation(fields: [deliveryGroupId], references: [id], onDelete: Cascade)
  notificationEvent  NotificationEvent? @relation(fields: [notificationEventId], references: [id], onDelete: SetNull)
  contact            Contact            @relation(fields: [contactId], references: [contactId], onDelete: Restrict)

  @@unique([deliveryGroupId, deliveryDate])
  @@index([orderId])
  @@index([deliveryGroupId])
  @@index([notificationEventId])
  @@index([contactId])
  @@index([orderType, orderNumber])
  @@index([deliveryDate])
  @@index([status])
  @@index([responseChannel])
  @@index([requestedNewDate])
  @@index([reminderSentAt])
  @@index([noResponseAt])
  @@map("delivery_confirmations")
}

model SmsOptOut {
  id            String    @id @default(cuid())
  contactId     String?   @db.VarChar(64)
  phone         String    @db.VarChar(32)
  source        String?   @db.VarChar(64)
  reason        String?   @db.VarChar(1024)
  optedOutAt    DateTime  @default(now())
  optedBackInAt DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contact Contact? @relation(fields: [contactId], references: [contactId], onDelete: SetNull)

  @@index([contactId])
  @@index([phone])
  @@index([isActive])
  @@index([phone, isActive])
  @@map("sms_opt_outs")
}

model EmailOptOut {
  id            String    @id @default(cuid())
  contactId     String?   @db.VarChar(64)
  email         String    @db.VarChar(256)
  source        String?   @db.VarChar(64)
  reason        String?   @db.VarChar(1024)
  optedOutAt    DateTime  @default(now())
  optedBackInAt DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contact Contact? @relation(fields: [contactId], references: [contactId], onDelete: SetNull)

  @@index([contactId])
  @@index([email])
  @@index([isActive])
  @@index([email, isActive])
  @@map("email_opt_outs")
}
